{
  "name": "vue-paged-media",
  "version": "0.0.0",
  "description": "A Vue library for previewing paged media layouts before printing.",
  "homepage": "https://github.com/pkc918/vue-paged-media",
  "bugs": {
    "url": "https://github.com/pkc918/vue-paged-media/issues"
  },
  "license": "MIT",
  "author": "青椒肉丝 <xiaopan2000918@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git@github.com:pkc918/vue-paged-media.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack && cp src/style.css dist/style.css",
    "dev": "vp pack --watch",
    "docs:build": "node scripts/clean-docs.mjs && vitepress build docs",
    "docs:dev": "vitepress dev docs --host 127.0.0.1",
    "docs:preview": "vitepress preview docs --host 127.0.0.1",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "oxc-minify": "^0.137.0",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.20",
    "vitepress": "^1.6.4",
    "vitepress-plugin-group-icons": "^1.7.5",
    "vue": "^3.5.38"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitepress": {
      "vite": "^5.4.19"
    },
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "npm@11.16.0",
  "inlinedDependencies": {
    "@babel/parser": "7.29.7",
    "@vue/compiler-core": "3.5.38",
    "@vue/compiler-dom": "3.5.38",
    "@vue/reactivity": "3.5.38",
    "@vue/runtime-core": "3.5.38",
    "@vue/runtime-dom": "3.5.38",
    "@vue/shared": "3.5.38",
    "csstype": "3.2.3",
    "entities": "7.0.1",
    "estree-walker": "2.0.2",
    "source-map-js": "1.2.1",
    "vue": "3.5.38"
  }
}
